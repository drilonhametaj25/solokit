# Stripe
# ===================
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Webhook secret - get from: https://dashboard.stripe.com/webhooks
# For local development, use Stripe CLI: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=

# ===================
# Resend (Email)
# ===================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Email sender address (must be verified in Resend)
EMAIL_FROM=noreply@solokit.co

# ===================
# Admin Configuration
